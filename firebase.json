{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/.*",
      ".git/**",
      ".firebase/**",
      ".agents/**",
      ".claude/**",
      "**/node_modules/**",
      "firebase-debug.log",
      ".server-*.log",
      "AGENTS.md",
      "CLAUDE.md",
      "**/functions/**",
      "README.md",
      "README_EN.md",
      "LICENSE",
      "index.js",
      "tools/**",
      "old/**",
      "screenshots/**",
      "docs/**",
      "design.md",
      "*.csv"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
