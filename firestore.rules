rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'ZPyHfPGUI4elNvRN2Q30ZqfzT6X2';
    }

    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{metadataId} {
      allow read: if metadataId in ['dashboard', 'steamSync', 'steamPlaytimeTracking'];
      allow write: if isAdmin();
    }

    match /steamPlaytimeMonths/{monthId} {
      allow read: if true;
      allow write: if false;

      match /apps/{appId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /steamPlaytimeState/{appId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
